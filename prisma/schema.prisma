// Schema do banco de dados - FinClara
// Etapa 1: Usuário, Receita, Despesa (categorias fixas)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TipoLancamento {
  RECEITA
  DESPESA
  INVESTIMENTO
}

enum PerfilInvestidor {
  CONSERVADOR
  MODERADO
  ARROJADO
}

enum TipoMeta {
  RESERVA
  VIAGEM
  CARRO
  FACULDADE
  APOSENTADORIA
  OUTRO
}

enum PlanoUsuario {
  FREE
  PRO
}

enum StatusAssinatura {
  SEM_ASSINATURA
  PENDENTE
  ATIVA
  PAUSADA
  CANCELADA
}

enum Categoria {
  SALARIO
  FREELANCE
  OUTRAS_RECEITAS
  MORADIA
  ALIMENTACAO
  TRANSPORTE
  SAUDE
  EDUCACAO
  LAZER
  ASSINATURAS
  OUTRAS_DESPESAS
  RESERVA_EMERGENCIA
  TESOURO_DIRETO
  RENDA_VARIAVEL
  OUTROS_INVESTIMENTOS
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  // senha não é armazenada aqui: autenticação é feita pelo Supabase Auth,
  // este id é o mesmo id do usuário no Supabase (auth.users.id)
  criadoEm  DateTime @default(now())
  perfilInvestidor PerfilInvestidor?
  telefone  String?
  endereco  String?
  // Só dígitos, sem máscara (validação de dígito verificador em lib/cpf.ts). Único: também trava
  // criação de contas repetidas com CPFs diferentes só para reaproveitar o trial de 7 dias.
  cpf              String?           @unique
  dataNascimento   DateTime?

  // Assinatura: trialEndsAt é gravado uma única vez na criação (ver garantirUsuario em
  // lib/auth.ts) com now()+7 dias. periodoAtualFim guarda até quando o acesso Pro vale mesmo
  // após cancelamento (o usuário já pagou aquele ciclo) — evita cortar o acesso na hora.
  trialEndsAt      DateTime          @default(now())
  plano            PlanoUsuario      @default(FREE)
  statusAssinatura StatusAssinatura  @default(SEM_ASSINATURA)
  mpAssinaturaId   String?           @unique
  periodoAtualFim  DateTime?

  lancamentos Lancamento[]
  dividas     Divida[]
  cartoes     CartaoCredito[]
  metas       Meta[]
  limitesCategoria LimiteCategoria[]
  patrimonioSnapshots PatrimonioSnapshot[]
  eventosWebhookAssinatura EventoWebhookAssinatura[]

  @@map("usuarios")
}

model Lancamento {
  id          String         @id @default(uuid())
  usuarioId   String
  usuario     Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  tipo        TipoLancamento
  categoria   Categoria
  descricao   String
  valor       Decimal        @db.Decimal(12, 2)
  data        DateTime
  recorrente  Boolean        @default(false)
  // Agrupa todas as ocorrências geradas de um mesmo lançamento recorrente,
  // permitindo excluir "este e os futuros" sem afetar meses já passados.
  serieRecorrenciaId String?
  // Vínculo opcional com uma meta: um registro "Guardei" pode alimentar uma meta, e guardar
  // dinheiro numa meta gera este lançamento — o mesmo dinheiro é digitado uma vez só.
  // SetNull: excluir a meta preserva o histórico do lançamento como investimento avulso.
  metaId      String?
  meta        Meta?          @relation(fields: [metaId], references: [id], onDelete: SetNull)

  criadoEm    DateTime       @default(now())
  atualizadoEm DateTime      @updatedAt

  @@index([usuarioId, data])
  @@index([serieRecorrenciaId])
  @@map("lancamentos")
}

model Divida {
  id            String    @id @default(uuid())
  usuarioId     String
  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  descricao     String
  // Valor total no momento do cadastro, preservado para calcular o percentual já quitado
  // (valorTotal vai sendo abatido a cada pagamento, valorOriginal nunca muda).
  valorOriginal Decimal   @default(0) @db.Decimal(12, 2)
  valorTotal    Decimal   @db.Decimal(12, 2)
  valorParcela  Decimal   @db.Decimal(12, 2)
  taxaJuros     Decimal   @db.Decimal(5, 2) // percentual ao mês
  // Quando o usuário não sabe os juros: taxaJuros grava 0 e a dívida é tratada como cara por
  // padrão conservador (ver ehDividaCara em lib/dividas.ts), até que o usuário atualize a taxa.
  jurosDesconhecidos Boolean @default(false)
  // Opcional: como o usuário pensa a dívida no dia a dia, permite validar o progresso além do
  // percentual quitado calculado por valor.
  parcelasRestantes Int?
  vencimento    DateTime
  quitada       Boolean   @default(false)
  quitadaEm     DateTime?

  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  @@index([usuarioId])
  @@map("dividas")
}

model CartaoCredito {
  id            String   @id @default(uuid())
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  nome          String
  limite        Decimal  @db.Decimal(12, 2)
  diaFechamento Int
  diaVencimento Int

  compras       CompraParcelada[]

  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  @@index([usuarioId])
  @@map("cartoes_credito")
}

model CompraParcelada {
  id          String        @id @default(uuid())
  cartaoId    String
  cartao      CartaoCredito @relation(fields: [cartaoId], references: [id], onDelete: Cascade)

  descricao   String
  valorTotal  Decimal       @db.Decimal(12, 2)
  numParcelas Int
  dataCompra  DateTime
  // Integra a parcela do mês nos Limites por categoria e no comparativo de alocação da renda.
  categoria   Categoria     @default(OUTRAS_DESPESAS)

  criadoEm    DateTime      @default(now())

  @@index([cartaoId])
  @@map("compras_parceladas")
}

model Meta {
  id           String   @id @default(uuid())
  usuarioId    String
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  tipo         TipoMeta
  descricao    String
  valorAlvo    Decimal  @db.Decimal(12, 2)
  valorAtual   Decimal  @db.Decimal(12, 2) @default(0)
  prazo        DateTime

  lancamentos  Lancamento[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([usuarioId])
  @@map("metas")
}

model LimiteCategoria {
  id           String    @id @default(uuid())
  usuarioId    String
  usuario      Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  categoria    Categoria
  valorLimite  Decimal   @db.Decimal(12, 2)

  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  @@unique([usuarioId, categoria])
  @@map("limites_categoria")
}

model PatrimonioSnapshot {
  id         String   @id @default(uuid())
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  ano        Int
  mes        Int
  patrimonio Decimal  @db.Decimal(12, 2)

  criadoEm   DateTime @default(now())

  // Uma "foto" por usuário por mês — registrada automaticamente quando o usuário acessa o
  // dashboard no mês corrente, para acumular histórico ao longo do tempo.
  @@unique([usuarioId, ano, mes])
  @@map("patrimonio_snapshots")
}

model EventoWebhookAssinatura {
  id        String   @id @default(uuid())
  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  // Id do evento/notificação do Mercado Pago — garante idempotência: o mesmo evento pode chegar
  // mais de uma vez (retry), então tratamos apenas a primeira ocorrência.
  mpEventoId   String   @unique
  tipo         String
  payload      Json
  processadoEm DateTime @default(now())

  @@map("eventos_webhook_assinatura")
}
