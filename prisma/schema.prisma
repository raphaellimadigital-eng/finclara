// Schema do banco de dados - FinClara
// Etapa 1: Usuário, Receita, Despesa (categorias fixas)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TipoLancamento {
  RECEITA
  DESPESA
  INVESTIMENTO
}

enum PerfilInvestidor {
  CONSERVADOR
  MODERADO
  ARROJADO
}

enum TipoMeta {
  RESERVA
  VIAGEM
  CARRO
  FACULDADE
  APOSENTADORIA
  OUTRO
}

enum Categoria {
  SALARIO
  FREELANCE
  OUTRAS_RECEITAS
  MORADIA
  ALIMENTACAO
  TRANSPORTE
  SAUDE
  EDUCACAO
  LAZER
  ASSINATURAS
  OUTRAS_DESPESAS
  RESERVA_EMERGENCIA
  TESOURO_DIRETO
  RENDA_VARIAVEL
  OUTROS_INVESTIMENTOS
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  // senha não é armazenada aqui: autenticação é feita pelo Supabase Auth,
  // este id é o mesmo id do usuário no Supabase (auth.users.id)
  criadoEm  DateTime @default(now())
  perfilInvestidor PerfilInvestidor?

  lancamentos Lancamento[]
  dividas     Divida[]
  cartoes     CartaoCredito[]
  metas       Meta[]

  @@map("usuarios")
}

model Lancamento {
  id          String         @id @default(uuid())
  usuarioId   String
  usuario     Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  tipo        TipoLancamento
  categoria   Categoria
  descricao   String
  valor       Decimal        @db.Decimal(12, 2)
  data        DateTime
  recorrente  Boolean        @default(false)

  criadoEm    DateTime       @default(now())
  atualizadoEm DateTime      @updatedAt

  @@index([usuarioId, data])
  @@map("lancamentos")
}

model Divida {
  id           String   @id @default(uuid())
  usuarioId    String
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  descricao    String
  valorTotal   Decimal  @db.Decimal(12, 2)
  valorParcela Decimal  @db.Decimal(12, 2)
  taxaJuros    Decimal  @db.Decimal(5, 2) // percentual ao mês
  vencimento   DateTime

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([usuarioId])
  @@map("dividas")
}

model CartaoCredito {
  id            String   @id @default(uuid())
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  nome          String
  limite        Decimal  @db.Decimal(12, 2)
  diaFechamento Int
  diaVencimento Int

  compras       CompraParcelada[]

  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  @@index([usuarioId])
  @@map("cartoes_credito")
}

model CompraParcelada {
  id          String        @id @default(uuid())
  cartaoId    String
  cartao      CartaoCredito @relation(fields: [cartaoId], references: [id], onDelete: Cascade)

  descricao   String
  valorTotal  Decimal       @db.Decimal(12, 2)
  numParcelas Int
  dataCompra  DateTime

  criadoEm    DateTime      @default(now())

  @@index([cartaoId])
  @@map("compras_parceladas")
}

model Meta {
  id           String   @id @default(uuid())
  usuarioId    String
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  tipo         TipoMeta
  descricao    String
  valorAlvo    Decimal  @db.Decimal(12, 2)
  valorAtual   Decimal  @db.Decimal(12, 2) @default(0)
  prazo        DateTime

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([usuarioId])
  @@map("metas")
}
