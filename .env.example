# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase

# Banco de dados (Supabase > Settings > Database > Connection string > URI)
DATABASE_URL="postgresql://postgres:[SUA-SENHA]@db.[SEU-PROJETO].supabase.co:5432/postgres"

# Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://[SEU-PROJETO].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[SUA-ANON-KEY]"

# Google Gemini (gratuito) - gere em https://aistudio.google.com/apikey
GEMINI_API_KEY="[SUA-GEMINI-API-KEY]"
