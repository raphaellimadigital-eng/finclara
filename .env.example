# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase

# Banco de dados (Supabase > Settings > Database > Connection string > URI)
DATABASE_URL="postgresql://postgres:[SUA-SENHA]@db.[SEU-PROJETO].supabase.co:5432/postgres"

# Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://[SEU-PROJETO].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[SUA-ANON-KEY]"

# Google Gemini (gratuito) - gere em https://aistudio.google.com/apikey
GEMINI_API_KEY="[SUA-GEMINI-API-KEY]"

# Resend (gratuito) - gere em https://resend.com/api-keys - usado pelo formulário de suporte
RESEND_API_KEY="[SUA-RESEND-API-KEY]"

# URL pública do site (sem barra no final) - usada para montar o back_url do checkout de
# assinatura. Em produção, use a URL do domínio publicado.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Mercado Pago (Suas integrações > Credenciais) - assinatura do plano Pro
MERCADOPAGO_ACCESS_TOKEN="[SEU-ACCESS-TOKEN]"
MERCADOPAGO_WEBHOOK_SECRET="[SUA-CHAVE-SECRETA-DO-WEBHOOK]"
# Gerado rodando `npx tsx scripts/criar-plano-mercadopago.ts` (ver README)
MERCADOPAGO_PLAN_ID="[ID-DO-PLANO-CRIADO-PELO-SCRIPT]"
